#!/usr/bin/env python3
"""
AUTHORIZED PENTEST: REAL Gmail + Instagram Account Creator
✅ Codespaces Compatible ✅ Chrome Auto-Fix ✅ Production Ready
"""

import asyncio
import json
import time
import random
import os
import sys
import subprocess
from typing import Dict, List
from datetime import datetime
from threading import Lock
import io
from PIL import Image, ImageDraw

# Auto-install missing deps
def install_deps():
    deps = ['aiohttp', 'pillow', 'faker']
    for dep in deps:
        try:
            __import__(dep)
        except ImportError:
            subprocess.check_call([sys.executable, "-m", "pip", "install", dep, "--quiet"])
            print(f"✅ Installed {dep}")

install_deps()

import aiohttp
from faker import Faker

# Selenium with fallback
SELENIUM_AVAILABLE = False
try:
    import undetected_chromedriver as uc
    from selenium.webdriver.chrome.options import Options
    from selenium.webdriver.common.by import By
    from selenium.webdriver.support.ui import WebDriverWait
    from selenium.webdriver.support import expected_conditions as EC
    SELENIUM_AVAILABLE = True
    print("✅ Selenium loaded")
except:
    print("⚠️ Selenium not available - using API fallback")

class PerfectPairCreator:
    def __init__(self, target: int = 3):
        self.target = target
        self.start_time = time.time()
        self.stats = {'gmail': 0, 'ig': 0, 'pfp': 0, 'errors': 0}
        self.lock = Lock()
        self.fake = Faker()
        
        # ✅ Create directories
        for path in ['accounts', 'accounts/pfps', 'accounts/logs']:
            os.makedirs(path, exist_ok=True)
            
        self.log_file = f"accounts/logs/pentest_{int(time.time())}.log"
        self.g_accounts = []
        self.ig_accounts = []
        
        print("🚀 PERFECT PENTEST - REAL Account Creator")
        self.log("✅ System ready")

    def log(self, msg: str):
        ts = datetime.now().strftime("%H:%M:%S")
        line = f"[{ts}] {msg}"
        print(line)
        try:
            with open(self.log_file, 'a') as f:
                f.write(line + '\n')
        except:
            pass

    def setup_chrome(self) -> str:
        """Auto-setup Chrome binary"""
        chrome_paths = [
            '/usr/bin/google-chrome-stable',
            '/usr/bin/google-chrome', 
            '/snap/bin/chromium',
            '/usr/lib/chromium-browser/chromium-browser'
        ]
        
        for path in chrome_paths:
            if os.path.isfile(path):
                return path
        
        # Auto-install Chrome
        try:
            subprocess.run(['sudo', 'apt', 'update', '-qq'], capture_output=True)
            subprocess.run(['sudo', 'apt', 'install', '-y', 'google-chrome-stable'], 
                         capture_output=True, timeout=300)
            return '/usr/bin/google-chrome-stable'
        except:
            return None

    def create_driver(self):
        """✅ Perfect Chrome driver setup"""
        if not SELENIUM_AVAILABLE:
            return None
            
        chrome_binary = self.setup_chrome()
        if not chrome_binary:
            self.log("⚠️ No Chrome - using fallback")
            return None
        
        try:
            options = Options()
            options.binary_location = chrome_binary
            options.add_argument('--no-sandbox')
            options.add_argument('--disable-dev-shm-usage')
            options.add_argument('--disable-gpu')
            options.add_argument('--disable-extensions')
            options.add_argument('--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36')
            options.add_experimental_option("excludeSwitches", ["enable-automation"])
            options.add_experimental_option("useAutomationExtension", False)
            
            driver = uc.Chrome(options=options, version_main=120)
            driver.execute_script("Object.defineProperty(navigator, 'webdriver', {get: () => undefined})")
            return driver
        except Exception as e:
            self.log(f"Driver error: {str(e)[:60]}")
            return None

    def generate_profile(self) -> Dict:
        """Realistic profile generator"""
        first_names = ['Tino', 'Tinashe', 'Shamie', 'John', 'Mary']
        last_names = ['Magumbo', 'Smith', 'Brown']
        
        first = random.choice(first_names)
        last = random.choice(last_names)
        num = random.randint(100, 999)
        
        gmail = f"{first.lower()}{num}@gmail.com"
        password = f"{first.lower()}{random.randint(1000, 9999)}@P"
        ig_user = f"{first.lower()}{random.randint(10, 99)}"
        
        return {
            'id': f"p{random.randint(10000, 99999)}",
            'first': first, 'last': last, 'full': f"{first} {last}",
            'gmail': gmail, 'pass': password, 'ig': ig_user,
            'status': 'pending', 'created': datetime.now().isoformat()
        }

    async def get_profile_pic(self, session: aiohttp.ClientSession, profile: Dict) -> str:
        """Download or generate PFP"""
        try:
            url = "https://images.unsplash.com/photo-1543466835-00a7907e9de1?w=300"
            async with session.get(url, timeout=10) as resp:
                if resp.status == 200:
                    img = Image.open(io.BytesIO(await resp.read())).resize((300, 300))
                    path = f"accounts/pfps/{profile['id']}.jpg"
                    img.save(path, 'JPEG', quality=90)
                    self.stats['pfp'] += 1
                    return path
        except:
            pass
        
        # Fallback colored square
        color = tuple([random.randint(50, 200) for _ in range(3)])
        img = Image.new('RGB', (300, 300), color)
        draw = ImageDraw.Draw(img)
        draw.text((100, 120), profile['id'][1:3].upper(), fill='white')
        path = f"accounts/pfps/{profile['id']}.jpg"
        img.save(path)
        return path

    async def create_gmail(self, profile: Dict, session: aiohttp.ClientSession) -> bool:
        """Create REAL Gmail account"""
        self.log(f"📧 Creating: {profile['gmail']}")
        profile['pfp'] = await self.get_profile_pic(session, profile)
        
        driver = self.create_driver()
        if not driver:
            return False
        
        try:
            driver.get("https://accounts.google.com/signup")
            await asyncio.sleep(3)
            
            # Fill form human-like
            form_data = [
                ('firstName', profile['first']),
                ('lastName', profile['last']),
                ('username', profile['gmail'].split('@')[0]),
                ('Passwd', profile['pass']),
                ('ConfirmPasswd', profile['pass'])
            ]
            
            for field_id, value in form_data:
                try:
                    elem = WebDriverWait(driver, 10).until(
                        EC.presence_of_element_located((By.ID, field_id))
                    )
                    elem.clear()
                    for char in value:
                        elem.send_keys(char)
                        await asyncio.sleep(0.1)
                    await asyncio.sleep(0.3)
                except:
                    continue
            
            # Submit
            btn = driver.find_element(By.XPATH, "//button//span[contains(text(),'Next')]")
            btn.click()
            await asyncio.sleep(15)
            
            # Verify success
            current_url = driver.current_url
            if any(x in current_url for x in ['myaccount.google.com', 'gmail.com']):
                profile['status'] = 'gmail_complete'
                with self.lock:
                    self.g_accounts.append(profile.copy())
                    self.stats['gmail'] += 1
                self.save_data()
                self.log(f"✅ GMAIL SUCCESS: {profile['gmail']}")
                return True
                
        except Exception as e:
            self.stats['errors'] += 1
            self.log(f"❌ Gmail failed: {str(e)[:60]}")
        finally:
            try:
                driver.quit()
            except:
                pass
        return False

    async def create_instagram(self, profile: Dict, session: aiohttp.ClientSession) -> bool:
        """Create REAL Instagram account"""
        self.log(f"📱 Creating: @{profile['ig']}")
        
        driver = self.create_driver()
        if not driver:
            return False
        
        try:
            driver.get("https://www.instagram.com/accounts/emailsignup/")
            await asyncio.sleep(4)
            
            form_data = [
                ('emailOrPhone', profile['gmail']),
                ('fullName', profile['full']),
                ('username', profile['ig']),
                ('password', profile['pass'])
            ]
            
            for name, value in form_data:
                elem = WebDriverWait(driver, 10).until(
                    EC.presence_of_element_located((By.NAME, name))
                )
                elem.send_keys(value)
                await asyncio.sleep(0.5)
            
            submit = driver.find_element(By.XPATH, "//button[@type='submit']")
            submit.click()
            await asyncio.sleep(15)
            
            if "instagram.com" in driver.current_url.lower():
                with self.lock:
                    self.ig_accounts.append(profile.copy())
                    self.stats['ig'] += 1
                self.save_data()
                self.log(f"✅ IG SUCCESS: @{profile['ig']}")
                return True
                
        except Exception as e:
            self.log(f"❌ IG failed: {str(e)[:60]}")
        finally:
            try:
                driver.quit()
            except:
                pass
        return False

    def save_data(self):
        """Save all accounts"""
        try:
            json.dump(self.g_accounts, open("accounts/gmail_accounts.json", 'w'), indent=2)
            json.dump(self.ig_accounts, open("accounts/ig_accounts.json", 'w'), indent=2)
            json.dump(self.stats, open("accounts/stats.json", 'w'), indent=2)
        except:
            pass

    async def run(self):
        """Main execution"""
        self.log(f"🎯 Starting {self.target} REAL pairs")
        
        timeout = aiohttp.ClientTimeout(total=30)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            for i in range(self.target):
                profile = self.generate_profile()
                
                # Gmail first
                if await self.create_gmail(profile, session):
                    await self.create_instagram(profile, session)
                
                self.log(f"📊 [{i+1}/{self.target}] G:{self.stats['gmail']} I:{self.stats['ig']}")
                await asyncio.sleep(random.uniform(30, 50))
        
        self.final_report()

    def final_report(self):
        pairs = min(self.stats['gmail'], self.stats['ig'])
        elapsed = time.time() - self.start_time
        self.log("=" * 60)
        self.log("🏆 PENTEST COMPLETE")
        self.log(f"✅ Gmail: {self.stats['gmail']}")
        self.log(f"✅ Instagram: {self.stats['ig']}")
        self.log(f"🔗 Pairs: {pairs}")
        self.log(f"⏱️ Time: {elapsed/60:.1f}min")
        self.log("📁 accounts/gmail_accounts.json")
        self.log("📁 accounts/ig_accounts.json")
        self.log("=" * 60)

if __name__ == "__main__":
    try:
        asyncio.run(PerfectPairCreator(3).run())
    except KeyboardInterrupt:
        print("\n⏹️ Stopped")
    except Exception as e:
        print(f"💥 Error: {e}")
        print("🔧 pip install undetected-chromedriver selenium")
